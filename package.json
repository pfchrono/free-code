{
  "name": "free-code-source",
  "version": "0.6.4",
  "private": true,
  "description": "Freecode CLI workspace for agentic coding.",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "bin": {
    "free-code": "cli",
    "free-code-source": "cli"
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "scripts": {
    "preinstall": "bun run ./scripts/preinstall.ts",
    "release:metadata:pre-commit": "bun run ./scripts/update-release-metadata.ts pre-commit",
    "release:metadata:prepare-commit-msg": "bun run ./scripts/update-release-metadata.ts prepare-commit-msg",
    "build": "bun run ./scripts/build.ts",
    "build:dev": "bun run ./scripts/build.ts --dev",
    "build:dev:full": "bun run ./scripts/build.ts --dev --feature-set=dev-full",
    "build:no-telemetry": "bun run ./scripts/build.ts --no-telemetry",
    "build:dev:full:no-telemetry": "bun run ./scripts/build.ts --dev --feature-set=dev-full --no-telemetry",
    "compile": "bun run ./scripts/build.ts --compile",
    "compile:dev:full": "bun run ./scripts/build.ts --compile --dev --feature-set=dev-full",
    "compile:no-telemetry": "bun run ./scripts/build.ts --compile --no-telemetry",
    "compile:dev:full:no-telemetry": "bun run ./scripts/build.ts --compile --dev --feature-set=dev-full --no-telemetry",
    "dev": "bun run ./src/entrypoints/cli.tsx",
    "dev:profile": "bun run ./scripts/provider-launch.ts",
    "dev:profile:auto": "bun run ./scripts/provider-launch.ts auto --recommend",
    "dev:profile:codex": "bun run ./scripts/provider-launch.ts codex",
    "dev:profile:openrouter": "bun run ./scripts/provider-launch.ts openrouter",
    "dev:profile:lmstudio": "bun run ./scripts/provider-launch.ts lmstudio",
    "dev:profile:copilot": "bun run ./scripts/provider-launch.ts copilot",
    "dev:profile:openai": "bun run ./scripts/provider-launch.ts openai",
    "dev:profile:minimax": "bun run ./scripts/provider-launch.ts minimax",
    "dev:profile:zen": "bun run ./scripts/provider-launch.ts zen",
    "dev:profile:firstparty": "bun run ./scripts/provider-launch.ts firstParty",
    "dev:grpc": "bun run ./scripts/start-grpc.ts",
    "dev:grpc:stop": "bun run ./scripts/stop-grpc.ts",
    "dev:grpc:cli": "bun run ./scripts/grpc-cli.ts",
    "dev:headless-transport": "bun run ./scripts/headless-transport-server.ts",
    "test:headless-integration": "bun run ./scripts/headless-integration.ts",
    "test:headless-transport": "bun run ./scripts/headless-transport-smoke.ts",
    "doctor:provider": "bun run ./scripts/provider-doctor.ts",
    "profile:init": "bun run ./scripts/provider-bootstrap.ts",
    "profile:auto": "bun run ./scripts/provider-bootstrap.ts --provider auto",
    "profile:codex": "bun run ./scripts/provider-bootstrap.ts --provider codex",
    "profile:openrouter": "bun run ./scripts/provider-bootstrap.ts --provider openrouter",
    "profile:lmstudio": "bun run ./scripts/provider-bootstrap.ts --provider lmstudio",
    "profile:copilot": "bun run ./scripts/provider-bootstrap.ts --provider copilot",
    "profile:openai": "bun run ./scripts/provider-bootstrap.ts --provider openai",
    "profile:minimax": "bun run ./scripts/provider-bootstrap.ts --provider minimax",
    "profile:zen": "bun run ./scripts/provider-bootstrap.ts --provider zen",
    "profile:firstparty": "bun run ./scripts/provider-bootstrap.ts --provider firstParty",
    "verify:no-phone-home": "bun run ./scripts/verify-no-phone-home.ts",
    "verify:no-phone-home:compile": "bun run ./scripts/verify-no-phone-home.ts dist/cli",
    "test": "bun test",
    "test:provider": "bun test ./src/utils/model/providers.test.ts"
  },
